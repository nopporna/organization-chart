# Google SSO (FR014 Option A)
GOOGLE_CLIENT_ID=709301674225-dbb5ul4h9edul2vmk47mrtt068siq7f1.apps.googleusercontent.com
GOOGLE_ALLOWED_DOMAIN=tripetch-it.co.th
VITE_GOOGLE_CLIENT_ID=709301674225-dbb5ul4h9edul2vmk47mrtt068siq7f1.apps.googleusercontent.com
VITE_GOOGLE_ALLOWED_DOMAIN=tripetch-it.co.th

# Optional: default spreadsheet ID loaded after sign-in
VITE_DEFAULT_SPREADSHEET_ID=

# Optional: comma-separated admin emails who can edit.
# If empty, every signed-in user is treated as admin.
# Example: VITE_ADMIN_EMAILS=admin@tripetch-it.co.th,boss@tripetch-it.co.th
VITE_ADMIN_EMAILS=

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
